<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="?android:colorBackground">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="?android:textColorPrimary"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_subtitle"
        android:textSize="14sp"
        android:textColor="?android:textColorSecondary"
        android:layout_marginBottom="32dp" />

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_label"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textColor="?android:textColorSecondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_checking"
            android:textSize="16sp"
            android:textColor="?android:textColorPrimary" />

    </LinearLayout>

    <!-- Video Selection Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="20dp"
        android:layout_marginBottom="24dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/video_label"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:textColor="?android:textColorSecondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/video_path_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_video_selected"
            android:textSize="14sp"
            android:textColor="?android:textColorSecondary"
            android:maxLines="2"
            android:ellipsize="middle"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/select_video_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/select_video"
            android:backgroundTint="@color/primary"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Playback Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/play_btn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/play"
            android:textSize="16sp"
            android:backgroundTint="@color/accent"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/stop_btn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/stop"
            android:textSize="16sp"
            android:backgroundTint="@color/stop_color"
            android:textColor="#FFFFFF"
            android:enabled="false"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
